rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All user data is under /users/{userId}
    // Only the authenticated user can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Projects subcollection
      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Workstreams subcollection
        match /workstreams/{workstreamId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;

          // Updates subcollection
          match /updates/{updateId} {
            allow read, write: if request.auth != null && request.auth.uid == userId;
          }
        }
      }

      // Agent tokens subcollection
      match /agentTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
